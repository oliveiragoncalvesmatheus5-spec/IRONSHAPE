# =============================================================================
# IronShape — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# No Vercel: adicione cada variável em Settings > Environment Variables
# =============================================================================

# ------------------------------------------------------------------------------
# ANTHROPIC (obrigatório — geração de cardápio e análise de alimentos)
# Obtenha em: https://console.anthropic.com → API Keys
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...

# ------------------------------------------------------------------------------
# OPENAI (obrigatório — Iron Coach IA)
# Obtenha em: https://platform.openai.com/api-keys
# A chave fica apenas no backend. Não use prefixo VITE_.
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.5

# ------------------------------------------------------------------------------
# SUPABASE (obrigatório — autenticação e banco de dados)
# Obtenha em: https://supabase.com/dashboard → Settings > API
# ------------------------------------------------------------------------------
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Necessário apenas para executar migrations via /api/run-migration
# Obtenha em: Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ------------------------------------------------------------------------------
# ABACATEPAY (pagamentos e assinaturas)
# Obtenha em: https://app.abacatepay.com → Integrar → API Keys
# Se os PRODUCT_IDs não forem configurados, o app usa os links fixos abaixo como fallback.
# Webhook recomendado:
# https://seusite.com/api/payment-webhook?webhookSecret=SEU_SECRET
# Eventos: checkout.completed, subscription.completed, subscription.renewed, subscription.cancelled
# ------------------------------------------------------------------------------
ABACATEPAY_API_KEY=
ABACATEPAY_PRODUCT_PRO_ID=
ABACATEPAY_PRODUCT_ELITE_ID=
ABACATEPAY_CHECKOUT_PRO_URL=https://app.abacatepay.com/pay/bill_qcpZwfDkagE0js0dcQrLWTjq
ABACATEPAY_CHECKOUT_ELITE_URL=https://app.abacatepay.com/pay/bill_0mR4kgjeGnp5du3QSD5naMCU
ABACATEPAY_WEBHOOK_SECRET=
ABACATEPAY_WEBHOOK_SIGNATURE_KEY=

# ------------------------------------------------------------------------------
# APP (necessário para redirects após checkout)
# Em produção: URL completa do seu site (ex: https://meuapp.vercel.app)
# Em desenvolvimento: http://localhost:3000
# ------------------------------------------------------------------------------
APP_URL=https://meuapp.vercel.app

# ------------------------------------------------------------------------------
# GEMINI (opcional — não utilizado ativamente no momento)
# ------------------------------------------------------------------------------
GEMINI_API_KEY=

# ------------------------------------------------------------------------------
# WORKOUTX / EXERCISE MEDIA (recomendado — GIFs de execução)
# Obtenha em: https://workoutxapp.com/
# O backend usa esta chave e entrega os GIFs via proxy em /api/workoutx-gif/:id.
# ------------------------------------------------------------------------------
WORKOUTX_API_KEY=

# ------------------------------------------------------------------------------
# RAPIDAPI / EXERCISE MEDIA (legado/opcional — fallback se WorkoutX não encontrar)
# API no RapidAPI: "EDB WITH VIDEOS AND IMAGES BY ASCENDAPI"
# Host padrão usado pelo backend:
# edb-with-videos-and-images-by-ascendapi.p.rapidapi.com
# ------------------------------------------------------------------------------
RAPIDAPI_KEY=
RAPIDAPI_HOST=edb-with-videos-and-images-by-ascendapi.p.rapidapi.com
