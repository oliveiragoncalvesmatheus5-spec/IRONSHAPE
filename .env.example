# =============================================================================
# IronSaaS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# No Vercel: adicione cada variável em Settings > Environment Variables
# =============================================================================

# ------------------------------------------------------------------------------
# ANTHROPIC (obrigatório — geração de cardápio e análise de alimentos com IA)
# Obtenha em: https://console.anthropic.com → API Keys
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...

# ------------------------------------------------------------------------------
# SUPABASE (obrigatório — autenticação e banco de dados)
# Obtenha em: https://supabase.com/dashboard → Settings > API
# ------------------------------------------------------------------------------
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Necessário apenas para executar migrations via /api/run-migration
# Obtenha em: Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ------------------------------------------------------------------------------
# STRIPE (obrigatório para pagamentos — pode deixar vazio em desenvolvimento)
# Obtenha em: https://dashboard.stripe.com → Developers → API Keys
# ------------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ------------------------------------------------------------------------------
# APP (necessário para Stripe redirects após checkout)
# Em produção: URL completa do seu site (ex: https://meuapp.vercel.app)
# Em desenvolvimento: http://localhost:3000
# ------------------------------------------------------------------------------
APP_URL=https://meuapp.vercel.app

# ------------------------------------------------------------------------------
# GEMINI (opcional — não utilizado ativamente no momento)
# ------------------------------------------------------------------------------
GEMINI_API_KEY=
